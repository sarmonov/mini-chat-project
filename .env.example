# Bu faylni .env deb nusxalang va kerak bo'lsa qiymatlarni o'zgartiring.
# cp .env.example .env   (yoki qo'lda nusxa oling)

# PostgreSQL (asyncpg drayveri)
DATABASE_URL=postgresql+asyncpg://chat:chat@localhost:5432/chat

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# JWT — productionda albatta o'zgartiring
JWT_SECRET=dev-secret-change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Media
MAX_UPLOAD_MB=25
